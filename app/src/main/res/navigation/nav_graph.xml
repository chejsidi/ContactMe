<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Pantalla de login, destino inicial -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.contactme.ui.LoginFragment"
        android:label="ContactMe"
        tools:layout="@layout/fragment_login">

        <!-- Acción: ir al listado -->
        <action
            android:id="@+id/action_loginFragment_to_listFragment"
            app:destination="@id/listFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <!-- Placeholder para el siguiente commit -->
    <fragment
        android:id="@+id/listFragment"
        android:name="com.example.contactme.ui.ListFragment"
        android:label="Listado"/>

</navigation>